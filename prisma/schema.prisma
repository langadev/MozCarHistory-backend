generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int                 @id @default(autoincrement())
  email     String              @unique
  name      String?
  password  String
  createdAt DateTime            @default(now())
  role      String              @default("comprador")
  updatedAt DateTime            @updatedAt
  address   String?
  nuit      String?
  phone     String?
  records   MaintenanceRecord[]
  cars      Car[]
}

model Car {
  id          Int                 @id @default(autoincrement())
  plateNumber String              @unique
  vin         String?             @unique
  brandModel  String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  ownerId     Int?
  owner       User?               @relation(fields: [ownerId], references: [id])

  records     MaintenanceRecord[]
  photos      String[]            @default([])
}

model MaintenanceRecord {
  id          Int      @id @default(autoincrement())
  carId       Int
  mileage     Int
  description String
  parts       String?
  mechanic    String?
  date        DateTime @default(now())
  workshopId  Int
  createdAt   DateTime @default(now())
  
  car         Car      @relation(fields: [carId], references: [id])
  workshop    User     @relation(fields: [workshopId], references: [id])
  photos      String[] @default([])
}
