generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  users       User[]
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  name               String?
  password           String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  address            String?
  nuit               String?
  phone              String?
  suspended          Boolean             @default(false)
  verified           Boolean             @default(false)
  mustChangePassword Boolean             @default(false)

  roleId             Int?
  role               Role?               @relation(fields: [roleId], references: [id])

  records            MaintenanceRecord[]
  cars               Car[]
  workshopMechanics  Mechanic[]          @relation("WorkshopMechanics")
  mechanicProfile    Mechanic?           @relation("MechanicUser")
}

model Mechanic {
  id         Int       @id @default(autoincrement())
  name       String
  specialty  String?
  phone      String?
  photo      String?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  workshopId Int
  workshop   User                @relation("WorkshopMechanics", fields: [workshopId], references: [id])

  userId     Int?                @unique
  user       User?               @relation("MechanicUser", fields: [userId], references: [id])

  records    MaintenanceRecord[]
}

model Car {
  id             Int                 @id @default(autoincrement())
  plateNumber    String              @unique
  vin            String?             @unique
  brand          String
  model          String
  year           Int?
  color          String?
  fuelType       String?
  transmission   String?
  engineSize     String?
  bodyType       String?
  initialMileage Int?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  ownerId        Int?
  owner          User?               @relation(fields: [ownerId], references: [id])

  records        MaintenanceRecord[]
  photos         String[]            @default([])
}

model MaintenanceRecord {
  id                 Int       @id @default(autoincrement())
  carId              Int
  mileage            Int
  serviceType        String?
  description        String
  parts              String?
  cost               Int?
  nextServiceMileage Int?
  date               DateTime  @default(now())
  workshopId         Int
  mechanicId         Int?
  createdAt          DateTime  @default(now())

  car         Car       @relation(fields: [carId], references: [id])
  workshop    User      @relation(fields: [workshopId], references: [id])
  mechanic    Mechanic? @relation(fields: [mechanicId], references: [id])
  photos      String[]  @default([])
}
